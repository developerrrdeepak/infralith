# Copy this file to `.env` for local development.
# Next.js automatically loads `.env` during `npm run dev` and `npm run build`.

NODE_ENV=development
NEXTAUTH_SECRET=replace-with-strong-secret

# Optional local/dev auth
INFRALITH_DEV_AUTH_SECRET=replace-with-dev-password
INFRALITH_DEV_ALLOWED_EMAILS=engineer@example.com,admin@example.com

# Azure AD
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# Optional aliases for Azure SDK auth (Cosmos AAD mode). If empty, code falls back to AZURE_AD_* above.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_AD_APP_ROLE_ADMIN=Admin
AZURE_AD_APP_ROLE_SUPERVISOR=Supervisor
AZURE_AD_APP_ROLE_ENGINEER=Engineer

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=model-router
AZURE_OPENAI_TOP_DEPLOYMENT=gpt-5
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
# Legacy aliases also supported:
# AZURE_FORM_RECOGNIZER_ENDPOINT=
# AZURE_FORM_RECOGNIZER_KEY=

# Azure AI Search (RAG retrieval)
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_API_VERSION=2024-07-01
AZURE_AI_SEARCH_INDEX_NAME=
# Optional second index (for code books / historical projects)
AZURE_AI_SEARCH_SECONDARY_INDEX_NAME=
# Optional semantic/vector tuning
AZURE_AI_SEARCH_SEMANTIC_CONFIG=default
AZURE_AI_SEARCH_TITLE_FIELD=title
AZURE_AI_SEARCH_CONTENT_FIELD=content
AZURE_AI_SEARCH_SUMMARY_FIELD=summary
AZURE_AI_SEARCH_SOURCE_FIELD=source
AZURE_AI_SEARCH_COLLECTION_FIELD=collection
AZURE_AI_SEARCH_CREATED_AT_FIELD=createdAt
AZURE_AI_SEARCH_VECTOR_FIELD=
# Optional Azure OpenAI embedding deployment for hybrid vector retrieval
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Azure Cosmos DB
AZURE_COSMOS_CONNECTION_STRING=
COSMOS_ENDPOINT=
COSMOS_KEY=
AZURE_COSMOS_USE_AAD=false
AZURE_COSMOS_DATABASE_ID=InfralithDB
AZURE_COSMOS_CONTAINER_ID=BIMModels
AZURE_COSMOS_COLLAB_CONTAINER_ID=CollabState

# Optional external services
GNEWS_API_KEY=
USER_LOOKUP_URL=
USER_LOOKUP_TIMEOUT_MS=5000

# Optional signaling limits
MEET_MAX_ROOMS=200
MEET_MAX_PEERS_PER_ROOM=12

# Strict real-data pipeline mode (recommended for production)
# true  => fail fast when RAG/config/agent evidence is missing
# false => allow conservative fallback outputs for partial runs
INFRALITH_STRICT_REAL_DATA=true
INFRALITH_MIN_EXTRACTION_COVERAGE=70
INFRALITH_REQUIRED_STANDARD_TERMS=is 456,nbc,is 13920
INFRALITH_ALLOW_PARTIAL_REPORT=true

# Optional: Global Community UI text overrides
NEXT_PUBLIC_COMMUNITY_ENABLE_SEED=false
NEXT_PUBLIC_COMMUNITY_TITLE=Global Community
NEXT_PUBLIC_COMMUNITY_SUBTITLE=Collaboration feed for engineering updates, questions, and bounty challenges.
NEXT_PUBLIC_COMMUNITY_FEED_ALL=All
NEXT_PUBLIC_COMMUNITY_FEED_FOLLOWING=Following
NEXT_PUBLIC_COMMUNITY_FEED_BOUNTIES=Bounties
